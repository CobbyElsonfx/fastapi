# Copy to .env and fill in values.
# OPENAI_API_KEY=sk-...

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Comma-separated origins for Laravel / Vite dev (no trailing slashes on paths)
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://127.0.0.1:5173,http://localhost:5173

# Optional: override default app metadata
APP_NAME=AI Academic Intelligence Service
